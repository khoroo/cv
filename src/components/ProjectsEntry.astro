---
import githubSvg from '../assets/icons/github.svg?raw';
import wwwSvg from '../assets/icons/www.svg?raw';
const { title, time, description, listItems, githubLink, websiteLink, techUsed } = Astro.props;
---

<div class="mb-4">
    <div class="flex flex-wrap items-center gap-3 mb-2">
        <div class="flex items-center">
            <h3 class="text-lg font-semibold">{title}</h3>
            <span class="mx-2 text-gray-400">|</span>
            <span class="text-lg text-gray-600">{time}</span>
        </div>
        
        <div class="ml-auto flex gap-3 items-center">
            {githubLink && (
                <a href={githubLink} class="text-gray-700 hover:text-blue-600 transition-colors flex items-center text-sm">
                    <span class="mr-1">GitHub</span>
                    <span set:html={githubSvg} />
                </a>
            )}

            {websiteLink && (
                <a href={websiteLink} class="text-gray-700 hover:text-blue-600 transition-colors flex items-center text-sm">
                    <span class="mr-1">Link</span>
                    <span set:html={wwwSvg} />
                </a>
            )}
        </div>
    </div>

    <table class="w-full mb-2">
        <tbody>
            <tr>
                <td class="align-top pr-4 py-1 text-gray-700">{description}</td>
            </tr>
            {techUsed && (
                <tr>
                    <td class="align-top py-1">
                        <div class="flex flex-wrap gap-2">
                            {techUsed.map((tech: string) => (
                                <span class="bg-gray-200 px-2 py-1 rounded-md text-sm">{tech}</span>
                            ))}
                        </div>
                    </td>
                </tr>
            )}
            <tr>
                <td class="align-top py-1">
                    <ul class="list-disc list-outside pl-5">
                        {listItems.map((item: string) => (
                            <li class="pb-1">{item}</li>
                        ))}
                    </ul>
                </td>
            </tr>
        </tbody>
    </table>
</div>
